# ============================================================
# DomClaw Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Tailscale ----
# Auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral key for containers
TS_KEY=tskey-auth-xxxxxxxxxxxxx

# Tailscale hostname (appears in your tailnet)
TS_HOSTNAME=ai-commander

# ---- OpenClaw Gateway ----
# Gateway listening port (internal)
OPENCLAW_PORT=3100

# ---- OpenCode ----
# Host path for OpenCode runtime data (~/.opencode equivalent)
OPENCODE_DATA_HOST_PATH=./.opencode

# OpenCode internal HTTP port
OPENCODE_PORT=8080

# ---- Discord Bot ----
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ---- Traefik ----
# Your tailnet domain (e.g., your-tailnet.ts.net)
TAILNET_DOMAIN=your-tailnet.ts.net

# Traefik dashboard credentials (optional, admin via Tailscale only)
TRAEFIK_DASHBOARD_USER=admin

# ---- Paths ----
# Host path for OpenClaw runtime data (~/.openclaw equivalent)
OPENCLAW_DATA_HOST_PATH=./.openclaw

# Host path for OpenClaw projects workspace
OPENCLAW_WORKSPACE_PATH=./.openclaw/workspace

# ---- Resource Limits ----
# Max memory for the entire gateway (Docker deploy limit)
GATEWAY_MEMORY_LIMIT=4G
# ---- Resource Limits ----
# Max memory for the entire gateway (Docker deploy limit)
GATEWAY_MEMORY_LIMIT=4G

# ---- SyntheNode ----
# SyntheNode dashboard port (internal)
SYNTHENODE_PORT=8765

# SyntheNode Docker image (use local build or registry)
SYNTHENODE_IMAGE=phioranex/synthenode:latest

# SyntheNode config file path
SYNTHENODE_CONFIG_PATH=./config/synthenode.yaml

# SyntheNode workspace path
SYNTHENODE_WORKSPACE_PATH=./workspace

# SyntheNode memory limit
SYNTHENODE_MEMORY_LIMIT=2G

# Embeddings provider (openai or anthropic)
EMBEDDING_PROVIDER=openai

# OpenAI API key for embeddings
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Anthropic API key (alternative)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
