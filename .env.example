# ============================================================
# DomClaw Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Tailscale ----
# Auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral key for containers
TS_KEY=tskey-auth-xxxxxxxxxxxxx

# Tailscale hostname (appears in your tailnet)
TS_HOSTNAME=ai-commander

# ---- OpenClaw Gateway ----
# Gateway listening port (internal)
OPENCLAW_PORT=3100

# ---- Discord Bot ----
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ---- Traefik ----
# Your tailnet domain (e.g., your-tailnet.ts.net)
TAILNET_DOMAIN=your-tailnet.ts.net

# Traefik dashboard credentials (optional, admin via Tailscale only)
TRAEFIK_DASHBOARD_USER=admin

# ---- Resource Limits ----
# Max memory for the entire gateway (Docker deploy limit)
GATEWAY_MEMORY_LIMIT=4G
