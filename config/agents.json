{
    "$schema": "https://openclaw.dev/schemas/agents.json",
    "agents": [
        {
            "id": "resonode-expert",
            "name": "Resonode Expert",
            "description": "Resonode 프로젝트 전용 개발 에이전트. 아키텍처 설계, 코드 리뷰, 기술 문서 작성을 담당합니다.",
            "model": "claude-sonnet-4-20250514",
            "systemPrompt": "You are Resonode Expert, a specialized development agent for the Resonode project. You help with architecture design, code review, and technical documentation. Always respond in the language the user uses. Be concise but thorough.",
            "capabilities": [
                "code-review",
                "architecture",
                "documentation",
                "debugging"
            ],
            "workspace": "/workspace/projects/resonode",
            "resources": {
                "maxMemoryMB": 1024,
                "maxConcurrent": 3,
                "timeoutMs": 120000
            },
            "tools": [
                {
                    "name": "file-read",
                    "enabled": true
                },
                {
                    "name": "file-write",
                    "enabled": true
                },
                {
                    "name": "terminal",
                    "enabled": true
                },
                {
                    "name": "web-search",
                    "enabled": false
                }
            ]
        },
        {
            "id": "solana-guardian",
            "name": "Solana Guardian",
            "description": "Solana 블록체인 보안 모니터링 및 트랜잭션 알림 에이전트. 스마트 컨트랙트 감사, 지갑 모니터링, 이상 탐지를 수행합니다.",
            "model": "claude-sonnet-4-20250514",
            "systemPrompt": "You are Solana Guardian, a blockchain security agent. You monitor Solana transactions, audit smart contracts, and detect anomalies. Alert on suspicious activities. Always prioritize security and provide actionable insights.",
            "capabilities": [
                "blockchain-monitoring",
                "security-audit",
                "transaction-analysis",
                "anomaly-detection"
            ],
            "workspace": "/workspace/projects/solana",
            "resources": {
                "maxMemoryMB": 1024,
                "maxConcurrent": 2,
                "timeoutMs": 60000
            },
            "tools": [
                {
                    "name": "file-read",
                    "enabled": true
                },
                {
                    "name": "file-write",
                    "enabled": false
                },
                {
                    "name": "terminal",
                    "enabled": true
                },
                {
                    "name": "web-search",
                    "enabled": true
                }
            ]
        },
        {
            "id": "remogent-worker",
            "name": "Remogent Worker",
            "description": "Remogent 원격 에이전트 시스템의 작업 실행 및 관리 에이전트. 원격 태스크 오케스트레이션과 상태 모니터링을 담당합니다.",
            "model": "claude-sonnet-4-20250514",
            "systemPrompt": "You are Remogent Worker, a remote agent orchestration specialist. You manage distributed tasks, monitor agent health, and ensure reliable execution of remote operations. Report status clearly and handle failures gracefully.",
            "capabilities": [
                "task-orchestration",
                "health-monitoring",
                "remote-execution",
                "error-handling"
            ],
            "workspace": "/workspace/projects/remogent",
            "resources": {
                "maxMemoryMB": 512,
                "maxConcurrent": 2,
                "timeoutMs": 90000
            },
            "tools": [
                {
                    "name": "file-read",
                    "enabled": true
                },
                {
                    "name": "file-write",
                    "enabled": true
                },
                {
                    "name": "terminal",
                    "enabled": true
                },
                {
                    "name": "web-search",
                    "enabled": false
                }
            ]
        }
    ]
}